# Backend
PORT=4000
NODE_ENV=development

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=voluntariado
DB_USER=app
DB_PASSWORD=app_password
DB_ROOT_PASSWORD=root_password

# Auth
JWT_SECRET=cambia-este-secreto-en-produccion
